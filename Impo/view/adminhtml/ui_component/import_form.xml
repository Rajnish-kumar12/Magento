<?xml version="1.0" encoding="UTF-8"?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">import_form.import_form_data_source</item>
            <item name="deps" xsi:type="string">import_form.import_form_data_source</item>
        </item>
        <item name="label" xsi:type="string" translate="true">fields</item>
        <item name="config" xsi:type="array">
            <item name="dataScope" xsi:type="string">data</item>
            <item name="namespace" xsi:type="string">import_form</item>
        </item>
        <item name="spinner" xsi:type="string">fields</item>
        
        <item name="template" xsi:type="string">templates/form/collapsible</item>
        <item name="buttons" xsi:type="array">
            <item name="Save" xsi:type="string">Training\Impo\Block\Adminhtml\Index\Edit\Button\SaveButton</item>
        </item>
    </argument>
    <settings>
    </settings>
    <dataSource name="import_form_data_source">
        <argument name="dataProvider" xsi:type="configurableObject">
            <argument name="class" xsi:type="string">Training\Impo\Model\DataProvider</argument>
            <argument name="name" xsi:type="string">import_form_data_source</argument>
            <argument name="primaryFieldName" xsi:type="string">entity_id</argument>
            <argument name="requestFieldName" xsi:type="string">entity_id</argument>
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="submit_url" xsi:type="url" path="impor/index/save" />
                </item>
            </argument>
        </argument>
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_Ui/js/form/provider</item>
            </item>
        </argument>
    </dataSource>
    <fieldset name="fields">
        <argument name="data" xsi:type="array">
            <item name="config" xsi:type="array">
                <item name="collapsible" xsi:type="boolean">false</item>
                <item name="label" xsi:type="string" translate="true">xml files</item>
                <item name="sortOrder" xsi:type="number">20</item>
            </item>
        </argument>
        <field name="import_xml">
        <argument name="data" xsi:type="array">
         <item name="options" xsi:type="object">Training\Impo\Model\Source\FileList</item>
            <item name="config" xsi:type="array">
                <item name="filter" xsi:type="string">select</item>
                <item name="editor" xsi:type="string">select</item>
                <item name="label" xsi:type="string" translate="true">Import Product files</item>
                <item name="formElement" xsi:type="string">select</item>
            </item>
        </argument>
        </field>

    </fieldset>
</form>
